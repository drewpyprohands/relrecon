{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Relational Matching Recipe Schema",
  "description": "JSON Schema for validating recipe YAML configs. Usable for linting in CI/automated workflows. All object levels use additionalProperties: false to catch typos and YAML indent mistakes.",
  "type": "object",
  "required": [
    "name",
    "sources",
    "populations",
    "steps",
    "output"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable recipe name"
    },
    "description": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "file"
        ],
        "additionalProperties": false,
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to data file (CSV, Parquet, or any Polars-supported format)"
          },
          "type": {
            "type": "string",
            "enum": [
              "trusted_reference",
              "multi_population"
            ],
            "description": "Source type label (informational)"
          }
        }
      }
    },
    "populations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string"
          },
          "record_key": {
            "type": "string",
            "description": "Field that uniquely identifies each source record. Used for dedup in best_match mode. If omitted, dedup falls back to match field (may collapse records with duplicate names)."
          },
          "filter": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/filter_condition"
            }
          },
          "action": {
            "type": "string",
            "enum": [
              "exclude"
            ]
          },
          "invalid_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Fields in this population known to contain invalid/unreliable data. Informational \u2014 not used for matching logic."
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source",
          "destination",
          "match_fields"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "description": "Population name to match from"
          },
          "destination": {
            "type": "string",
            "description": "Population or source name to match against"
          },
          "match_fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "destination",
                "method",
                "tiers"
              ],
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": "string"
                },
                "destination": {
                  "type": "string"
                },
                "method": {
                  "type": "string",
                  "enum": [
                    "exact",
                    "fuzzy"
                  ]
                },
                "threshold": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100,
                  "default": 80,
                  "description": "Minimum fuzzy score (0-100) for method: fuzzy. Ignored for exact."
                },
                "scorer": {
                  "type": "string",
                  "enum": [
                    "token_sort_ratio",
                    "token_set_ratio",
                    "ratio",
                    "partial_ratio",
                    "WRatio"
                  ],
                  "default": "token_sort_ratio",
                  "description": "RapidFuzz scorer function for method: fuzzy. Ignored for exact."
                },
                "tiers": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "raw",
                      "clean",
                      "normalized"
                    ]
                  }
                }
              }
            }
          },
          "address_support": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "source": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "destination": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "parser": {
                "type": "string",
                "enum": [
                  "auto",
                  "libpostal",
                  "default"
                ],
                "default": "auto"
              },
              "threshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Minimum address score to keep a match. Records below this cascade to later steps."
              },
              "tiers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "raw",
                    "clean",
                    "normalized"
                  ]
                },
                "default": [
                  "raw",
                  "clean",
                  "normalized"
                ],
                "description": "Normalization tiers to try for address scoring. Default: all three. Order determines tie-breaking (first wins)."
              },
              "weights": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "street_name": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "default": 0.6,
                    "description": "Weight for street name component in address scoring (0.0-1.0). Remainder goes to full string score. Default: 0.6 (60% street + 40% full string). Applied whenever both addresses have a parseable street name."
                  }
                }
              },
              "require_street_match": {
                "type": "boolean",
                "default": false,
                "description": "When true, reject address matches where street names differ (street_match is false). Rejected records cascade to later steps or appear in Analysis with reason_code 'street_mismatch'. Default: false (street weighting only, no hard gate)."
              }
            }
          },
          "date_gate": {
            "type": "object",
            "required": [
              "field",
              "max_age_years",
              "applies_to"
            ],
            "additionalProperties": false,
            "description": "Legacy date recency filter. Prefer 'filters' with op: max_age_years instead. Both are supported \u2014 date_gate is internally converted to a filter.",
            "properties": {
              "field": {
                "type": "string"
              },
              "max_age_years": {
                "type": "number"
              },
              "applies_to": {
                "type": "string",
                "enum": [
                  "destination",
                  "source",
                  "both"
                ]
              }
            }
          },
          "filters": {
            "type": "array",
            "description": "Generic step-level filters applied before matching. Supports all population filter ops plus max_age_years.",
            "items": {
              "$ref": "#/definitions/step_filter_condition"
            }
          },
          "inherit": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "as"
              ],
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": "string",
                  "description": "Destination column to inherit on match"
                },
                "as": {
                  "type": "string",
                  "description": "Column name in output for the inherited value"
                }
              }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "format"
      ],
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "xlsx",
            "csv",
            "parquet"
          ]
        },
        "path": {
          "type": "string",
          "description": "Output path hint. CLI overrides this with a timestamped filename."
        },
        "match_mode": {
          "type": "string",
          "enum": [
            "best_match",
            "all_matches"
          ],
          "default": "best_match"
        },
        "tie_breaker": {
          "type": "object",
          "description": "Tie-breaker for selecting among duplicate destination matches. Sorts by column value after stripping optional prefix.",
          "additionalProperties": false,
          "required": [
            "column"
          ],
          "properties": {
            "column": {
              "type": "string",
              "description": "Destination column to sort by for tie-breaking"
            },
            "strip_prefix": {
              "type": "string",
              "description": "'alpha' strips all leading letters and parses the remainder as an integer for numeric sorting (e.g. 'S1013' -> 1013). Any other string is treated as a prefix to strip from the start of the value before sorting as text (e.g. 'S' strips leading 'S' only). Omit or set to empty string for plain string sorting."
            },
            "order": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc",
              "description": "Sort order: 'asc' (lowest wins, default) or 'desc' (highest wins)"
            }
          }
        },
        "tabs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "matched_records",
                  "unmatched_review"
                ]
              }
            }
          }
        },
        "columns": {
          "type": "object",
          "additionalProperties": false,
          "description": "Report column definitions. When omitted, hardcoded defaults are used (backward compatible).",
          "properties": {
            "matched": {
              "type": "array",
              "description": "Columns for the Matched tab, in display order.",
              "items": {
                "type": "object",
                "required": [
                  "header"
                ],
                "oneOf": [
                  {
                    "required": [
                      "field"
                    ],
                    "properties": {
                      "field": {
                        "type": "string",
                        "description": "Single DataFrame column name."
                      },
                      "header": {
                        "type": "string",
                        "description": "Display header in Excel."
                      }
                    },
                    "additionalProperties": false
                  },
                  {
                    "required": [
                      "fields"
                    ],
                    "properties": {
                      "fields": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1,
                        "description": "Variant column names to coalesce (for dest columns from different steps)."
                      },
                      "header": {
                        "type": "string",
                        "description": "Display header in Excel."
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "analysis": {
              "type": "array",
              "description": "Columns for the Analysis tab, in display order.",
              "items": {
                "type": "object",
                "required": [
                  "field",
                  "header"
                ],
                "additionalProperties": false,
                "properties": {
                  "field": {
                    "type": "string"
                  },
                  "header": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "step_defaults": {
      "type": "object",
      "description": "Default values merged into every step before validation. Step-level values win on conflict. Removed after expansion.",
      "additionalProperties": true
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stopwords": {
          "type": "string"
        },
        "aliases": {
          "type": "string"
        },
        "unicode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ranges": {
              "type": "string"
            },
            "mode": {
              "type": "string",
              "enum": [
                "normalize",
                "profile_only",
                "skip"
              ],
              "default": "skip"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "filter_condition": {
      "type": "object",
      "required": [
        "field",
        "op"
      ],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "starts_with",
            "not_starts_with",
            "contains",
            "contains_any",
            "is_not_null",
            "is_null"
          ]
        },
        "value": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "join": {
          "type": "string",
          "enum": [
            "and",
            "or"
          ],
          "default": "and"
        }
      }
    },
    "step_filter_condition": {
      "type": "object",
      "required": [
        "field",
        "op"
      ],
      "additionalProperties": false,
      "description": "Step-level filter. Supports all population filter ops plus max_age_years for date recency.",
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "starts_with",
            "not_starts_with",
            "contains",
            "contains_any",
            "max_age_years",
            "is_not_null",
            "is_null"
          ]
        },
        "value": {
          "description": "Filter value. String for text ops, number for max_age_years."
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "join": {
          "type": "string",
          "enum": [
            "and",
            "or"
          ],
          "default": "and"
        },
        "applies_to": {
          "type": "string",
          "enum": [
            "destination",
            "source",
            "both"
          ],
          "default": "destination",
          "description": "Which side of the match to apply the filter to."
        },
        "max_age_years": {
          "type": "number",
          "description": "Legacy field \u2014 prefer using op: max_age_years with value instead."
        }
      }
    }
  }
}
