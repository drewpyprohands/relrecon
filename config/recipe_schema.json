{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Relational Matching Recipe Schema",
  "description": "JSON Schema for validating recipe YAML configs. Usable for linting in CI/automated workflows. All object levels use additionalProperties: false to catch typos and YAML indent mistakes.",
  "type": "object",
  "required": [
    "name",
    "sources"
  ],
  "additionalProperties": false,
  "oneOf": [
    {
      "required": [
        "populations",
        "steps",
        "output"
      ]
    },
    {
      "required": [
        "phases"
      ],
      "not": {
        "required": [
          "output"
        ]
      }
    }
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable recipe name"
    },
    "description": {
      "type": "string"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "description": "Path to data file (CSV, TSV, or Parquet)"
          },
          "type": {
            "type": "string",
            "enum": [
              "trusted_reference",
              "multi_population"
            ],
            "description": "Source type label (informational)"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Subset of columns to load"
          },
          "loader": {
            "type": "string",
            "enum": [
              "file",
              "sql",
              "http"
            ],
            "description": "Loader type (default: file)"
          },
          "url": {
            "type": "string",
            "description": "URL to download (required for http loader). Supports ${VAR} env interpolation."
          },
          "format": {
            "type": "string",
            "enum": [
              "csv",
              "tsv",
              "parquet",
              "json",
              "jsonl",
              "zip"
            ],
            "description": "File format (auto-detected from URL if omitted)"
          },
          "zip_entry": {
            "type": "string",
            "description": "Specific file to extract from a ZIP archive. If omitted, uses single file or largest."
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "HTTP headers to send with the request"
          },
          "verify": {
            "description": "SSL verification: true, false, or path to CA cert bundle"
          },
          "timeout": {
            "type": "number",
            "default": 300,
            "description": "HTTP request timeout in seconds (default: 300)"
          },
          "driver": {
            "type": "string",
            "enum": [
              "sqlite",
              "postgresql",
              "postgres",
              "trino"
            ],
            "description": "Database driver (required for sql loader)"
          },
          "connection": {
            "type": "object",
            "description": "Connection config (supports ${VAR} env interpolation)",
            "additionalProperties": true
          },
          "query": {
            "type": "string",
            "description": "SQL query to execute"
          },
          "cache_ttl": {
            "type": "string",
            "description": "Cache TTL for SQL results. Examples: '24h', '12h', '30m', '7d', 'off'. Default: '24h'",
            "default": "24h"
          },
          "cache_format": {
            "type": "string",
            "enum": [
              "parquet",
              "csv"
            ],
            "default": "parquet",
            "description": "Cache file format. 'csv' produces Excel-openable files. Default: 'parquet'"
          },
          "url_from": {
            "type": "object",
            "description": "Resolve download URL from a JSON metadata API",
            "properties": {
              "endpoint": {
                "type": "string",
                "description": "URL of the JSON metadata API"
              },
              "json_path": {
                "type": "string",
                "description": "Dot-notation path to extract the download URL"
              }
            },
            "required": [
              "endpoint",
              "json_path"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "populations": {
      "$ref": "#/definitions/populations"
    },
    "steps": {
      "$ref": "#/definitions/steps"
    },
    "output": {
      "$ref": "#/definitions/output"
    },
    "step_defaults": {
      "type": "object",
      "description": "Default values merged into every step before validation. Step-level values win on conflict. Removed after expansion.",
      "additionalProperties": true
    },
    "exclusions": {
      "type": "string",
      "description": "Path to a global exclusions CSV (columns: step, vnd_id[, note]). Each row routes a vnd_id into the named step's exclude mechanism; excluded records cascade to later steps."
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stopwords": {
          "type": "string"
        },
        "aliases": {
          "type": "string"
        },
        "unicode": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ranges": {
              "type": "string"
            },
            "mode": {
              "type": "string",
              "enum": [
                "normalize",
                "profile_only",
                "skip"
              ],
              "default": "skip"
            }
          }
        }
      }
    },
    "phases": {
      "type": "array",
      "description": "Multi-phase pipeline. Each phase has its own populations and steps. Use _previous_matched as a source to chain phase outputs.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "populations",
          "steps"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable phase name"
          },
          "populations": {
            "$ref": "#/definitions/populations"
          },
          "steps": {
            "$ref": "#/definitions/steps"
          },
          "step_defaults": {
            "type": "object",
            "description": "Per-phase step defaults (overrides top-level step_defaults)",
            "additionalProperties": true
          },
          "output": {
            "$ref": "#/definitions/output"
          }
        }
      }
    }
  },
  "definitions": {
    "populations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "source": {
            "type": "string"
          },
          "record_key": {
            "type": "string",
            "description": "Field that uniquely identifies each source record. Used for dedup in best_match mode."
          },
          "filter": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/filter_condition"
            }
          },
          "action": {
            "type": "string",
            "enum": [
              "exclude"
            ],
            "description": "Population action: 'exclude' removes these records from matching"
          },
          "invalid_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Fields in this population known to contain invalid/unreliable data. Informational only."
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source",
          "destination",
          "match_fields"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable step name for reporting"
          },
          "source": {
            "type": "string",
            "description": "Population name to match from"
          },
          "destination": {
            "type": "string",
            "description": "Population or source name to match against"
          },
          "match_fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "destination",
                "method",
                "tiers"
              ],
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": "string",
                  "description": "Column in the source population to match from"
                },
                "destination": {
                  "type": "string",
                  "description": "Column in the destination population to match against"
                },
                "method": {
                  "type": "string",
                  "enum": [
                    "exact",
                    "fuzzy"
                  ],
                  "description": "Matching method: 'exact' for string equality, 'fuzzy' for similarity scoring"
                },
                "threshold": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100,
                  "default": 80,
                  "description": "Minimum fuzzy score (0-100) for method: fuzzy. Ignored for exact."
                },
                "scorer": {
                  "type": "string",
                  "enum": [
                    "token_sort_ratio",
                    "token_set_ratio",
                    "ratio",
                    "partial_ratio",
                    "WRatio"
                  ],
                  "default": "token_sort_ratio",
                  "description": "RapidFuzz scorer function for method: fuzzy. Ignored for exact."
                },
                "tiers": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "raw",
                      "clean",
                      "normalized"
                    ]
                  },
                  "description": "Normalization tiers to try, in order. Default: all three (raw, clean, normalized)"
                }
              }
            },
            "description": "Fields to match between source and destination populations"
          },
          "address_support": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "source": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Address column(s) in the source population"
              },
              "destination": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Address column(s) in the destination population"
              },
              "parser": {
                "type": "string",
                "enum": [
                  "auto",
                  "libpostal",
                  "default"
                ],
                "default": "auto",
                "description": "Address parser to use. Default: auto (libpostal if available, fallback to built-in)"
              },
              "threshold": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Minimum address score to keep a match. Records below this cascade to later steps."
              },
              "tiers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "raw",
                    "clean",
                    "normalized"
                  ]
                },
                "default": [
                  "raw",
                  "clean",
                  "normalized"
                ],
                "description": "Normalization tiers for address scoring. Default: all three. Order determines tie-breaking."
              },
              "weights": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "street_name": {
                    "type": "number",
                    "minimum": 0.0,
                    "maximum": 1.0,
                    "default": 0.6,
                    "description": "Weight for street name component (0.0-1.0). Remainder goes to full string score."
                  }
                },
                "description": "Component weights for address scoring"
              },
              "require_street_match": {
                "type": "boolean",
                "default": false,
                "description": "When true, reject address matches where street names differ. Rejected records cascade to later steps."
              }
            },
            "description": "Address scoring configuration for this step"
          },
          "date_gate": {
            "type": "object",
            "required": [
              "field",
              "max_age_years",
              "applies_to"
            ],
            "additionalProperties": false,
            "properties": {
              "field": {
                "type": "string",
                "description": "Date column to check for recency"
              },
              "max_age_years": {
                "type": "number",
                "description": "Maximum age in years. Records older than this are filtered out."
              },
              "applies_to": {
                "type": "string",
                "enum": [
                  "destination",
                  "source",
                  "both"
                ],
                "description": "Which population the date field belongs to: 'source' or 'destination'"
              }
            },
            "description": "Legacy date recency filter. Prefer 'filters' with op: max_age_years instead."
          },
          "filters": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/step_filter_condition"
            },
            "description": "Generic step-level filters applied before matching. Supports all population filter ops plus max_age_years."
          },
          "inherit": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source",
                "as"
              ],
              "additionalProperties": false,
              "properties": {
                "source": {
                  "type": "string",
                  "description": "Destination column to inherit on match"
                },
                "as": {
                  "type": "string",
                  "description": "Column name in output for the inherited value"
                }
              }
            },
            "description": "Columns to inherit from the destination record on match"
          },
          "exclude": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "description": "Field to match exclude values against (defaults to record_key)"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Exact values to exclude from this step"
              },
              "file": {
                "type": "string",
                "description": "CSV file with values to exclude (first column)"
              }
            },
            "additionalProperties": false,
            "description": "Skip specific source records from this step so they fall through to later steps"
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": [
        "format"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["matched", "enriched"],
          "default": "matched",
          "description": "Output mode. 'matched' (default) splits into matched/unmatched. 'enriched' left-joins match results onto the full source dataset -- every source row appears, with enrichment columns null where no match."
        },
        "enrich_source": {
          "type": "string",
          "description": "Source name to use as enrichment base (required when mode=enriched). All rows from this source appear in output."
        },
        "enrich_key": {
          "type": "string",
          "description": "Column in the enrichment source to join on (required when mode=enriched). Must exist in both the source and the matched results."
        },
        "format": {
          "type": "string",
          "enum": [
            "xlsx",
            "csv",
            "parquet"
          ],
          "description": "Data export format. CSV/Parquet produce raw data files. XLSX produces raw data (single Data tab) unless summary includes xlsx."
        },
        "path": {
          "type": "string",
          "description": "Output path hint. CLI overrides this with a timestamped filename."
        },
        "summary": {
          "description": "Summary/report generation. 'md' for markdown, 'xlsx' for formatted report with Summary tab, array for both, 'none' to disable. Omitting defaults to [md, xlsx] for top-level xlsx, none otherwise.",
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "none",
                "md",
                "xlsx"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "md",
                  "xlsx"
                ]
              }
            }
          ]
        },
        "match_mode": {
          "type": "string",
          "enum": [
            "best_match",
            "all_matches"
          ],
          "default": "best_match",
          "description": "Match selection mode: 'best_match' keeps one match per source record, 'all_matches' keeps all."
        },
        "tabs": {
          "type": "array",
          "description": "Deprecated. Tab generation is automatic (Summary + Matched + Analysis). This field is ignored.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        },
        "tie_breaker": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "column"
          ],
          "properties": {
            "column": {
              "type": "string",
              "description": "Destination column to sort by for tie-breaking"
            },
            "strip_prefix": {
              "type": "string",
              "description": "'alpha' strips leading letters and parses remainder as integer for numeric sorting"
            },
            "order": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc",
              "description": "Sort order: 'asc' (lowest wins, default) or 'desc' (highest wins)"
            }
          },
          "description": "Tie-breaker for selecting among duplicate destination matches."
        },
        "columns": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "matched": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "header"
                ],
                "oneOf": [
                  {
                    "required": [
                      "field"
                    ],
                    "properties": {
                      "field": {
                        "type": "string"
                      },
                      "header": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  },
                  {
                    "required": [
                      "fields"
                    ],
                    "properties": {
                      "fields": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1
                      },
                      "header": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              }
            },
            "analysis": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "field",
                  "header"
                ],
                "additionalProperties": false,
                "properties": {
                  "field": {
                    "type": "string"
                  },
                  "header": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "description": "Column definitions for data export and reports. When omitted, hardcoded defaults are used."
        }
      }
    },
    "filter_condition": {
      "type": "object",
      "required": [
        "field",
        "op"
      ],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "starts_with",
            "not_starts_with",
            "contains",
            "contains_any",
            "is_not_null",
            "is_null"
          ]
        },
        "value": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "join": {
          "type": "string",
          "enum": [
            "and",
            "or"
          ],
          "default": "and"
        },
        "ignore_case": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "step_filter_condition": {
      "type": "object",
      "required": [
        "field",
        "op"
      ],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string"
        },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "starts_with",
            "not_starts_with",
            "contains",
            "contains_any",
            "max_age_years",
            "is_not_null",
            "is_null"
          ]
        },
        "value": {
          "description": "Filter value. String for text ops, number for max_age_years."
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "join": {
          "type": "string",
          "enum": [
            "and",
            "or"
          ],
          "default": "and"
        },
        "applies_to": {
          "type": "string",
          "enum": [
            "destination",
            "source",
            "both"
          ],
          "default": "destination"
        },
        "max_age_years": {
          "type": "number"
        },
        "ignore_case": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
